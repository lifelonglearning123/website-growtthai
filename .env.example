# ---------------------------------------------------------------------------
# GoHighLevel (LeadConnector) — contact form integration
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` for local dev, and add the same variables in
# Vercel → Project → Settings → Environment Variables for production.

# The Sub-Account (Location) ID the leads should be created under.
GHL_LOCATION_ID=HgjeskkkSGbtRQ19CJKR

# A GHL API token with contacts write access.
# Recommended: a Private Integration token (Settings → Private Integrations)
# with the scopes: contacts.write, contacts.readonly
GHL_API_TOKEN=pit-57561cb8-b0e6-4a3d-8385-8297acb08733

# Optional: comma-separated tags added to every lead created from the site.
GHL_LEAD_TAGS=Website Lead,Growtth

# Optional: the "source" label stored on the contact in GHL.
GHL_LEAD_SOURCE=Growtth Website
